/* ========== PLANTDOCTOR AI PRO - COMPLETE STYLES ========== */
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

:root {
    --primary: #2ecc71;
    --primary-dark: #27ae60;
    --secondary: #3498db;
    --danger: #e74c3c;
    --warning: #f39c12;
    --dark: #1a1a2e;
    --light: #f8f9fa;
    --purple: #667eea;
    --purple-dark: #764ba2;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Plus Jakarta Sans', 'Inter', sans-serif;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) fixed !important;
    min-height: 100vh;
    color: #2c3e50;
    overflow-x: hidden;
}

.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

/* ========== PARTICLE BACKGROUND ========== */
#particle-background {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    z-index: 0 !important;
    pointer-events: none !important;
}

#particle-background canvas {
    width: 100% !important;
    height: 100% !important;
    display: block !important;
}

.navbar, .main-content, .fab-container, .ai-assistant, .notification-panel {
    position: relative !important;
    z-index: 2 !important;
}

/* ========== NAVIGATION ========== */
.navbar {
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(10px);
    padding: 12px 0;
    position: sticky;
    top: 0;
    z-index: 1000;
    box-shadow: 0 2px 20px rgba(0, 0, 0, 0.1);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
}

.nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

.nav-brand {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.4rem;
    font-weight: 700;
}

.brand-icon {
    color: var(--primary);
    font-size: 1.6rem;
}

.brand-text {
    background: linear-gradient(135deg, #667eea, #764ba2);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.pro-badge {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    padding: 2px 8px;
    border-radius: 12px;
    font-size: 0.65rem;
    font-weight: 600;
    margin-left: 5px;
    -webkit-text-fill-color: white;
}

.nav-menu {
    display: flex;
    gap: 8px;
}

.nav-link {
    text-decoration: none;
    color: var(--dark);
    font-weight: 500;
    padding: 8px 14px;
    border-radius: 8px;
    transition: all 0.3s;
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.9rem;
}

.nav-link i {
    font-size: 1rem;
}

.nav-link:hover {
    background: rgba(46, 204, 113, 0.1);
    color: var(--primary);
}

.nav-link.active {
    background: var(--primary);
    color: white;
}

.nav-actions {
    display: flex;
    align-items: center;
    gap: 12px;
}

.theme-toggle, .notification-btn {
    background: transparent;
    border: none;
    width: 38px;
    height: 38px;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--dark);
    font-size: 1.1rem;
    transition: all 0.3s;
    position: relative;
}

.theme-toggle:hover, .notification-btn:hover {
    background: rgba(0, 0, 0, 0.05);
}

.notification-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    background: var(--danger);
    color: white;
    font-size: 0.6rem;
    padding: 2px 5px;
    border-radius: 10px;
    font-weight: 600;
}

/* ========== USER PROFILE DROPDOWN ========== */
.user-profile-wrapper {
    position: relative;
}

.user-profile {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.3s;
}

.user-profile:hover {
    background: rgba(46, 204, 113, 0.1);
}

.user-profile img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--primary);
}

.user-profile span {
    font-weight: 500;
    color: #333;
    font-size: 0.9rem;
}

.user-profile i {
    font-size: 0.75rem;
    color: #888;
    transition: transform 0.3s;
}

.user-profile.active i {
    transform: rotate(180deg);
}

.user-dropdown {
    position: absolute;
    top: calc(100% + 10px);
    right: 0;
    background: white;
    border-radius: 12px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
    min-width: 200px;
    z-index: 1001;
    overflow: hidden;
    animation: slideDown 0.2s ease;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-10px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.user-dropdown a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    text-decoration: none;
    color: #333;
    transition: background 0.2s;
    font-size: 0.95rem;
}

.user-dropdown a i {
    width: 20px;
    color: var(--primary);
}

.user-dropdown a:hover {
    background: #f5f5f5;
}

.dropdown-divider {
    height: 1px;
    background: #eee;
    margin: 5px 0;
}

/* ========== SECTIONS ========== */
.section {
    display: none;
    padding: 20px 0;
}

.section.active {
    display: block;
}

/* ========== DASHBOARD ========== */
.dashboard-header {
    margin-bottom: 20px;
}

.dashboard-header h1 {
    color: white;
    font-size: 1.8rem;
    margin-bottom: 5px;
}

.greeting-message {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.95rem;
}

/* Stats Grid */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 18px;
    margin-bottom: 20px;
}

.stat-card {
    background: white;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s;
    display: flex;
    align-items: flex-start;
    gap: 15px;
}

.stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
}

.stat-card.gradient-1 { background: linear-gradient(135deg, #667eea, #764ba2); color: white; }
.stat-card.gradient-2 { background: linear-gradient(135deg, #2ecc71, #27ae60); color: white; }
.stat-card.gradient-3 { background: linear-gradient(135deg, #e74c3c, #c0392b); color: white; }
.stat-card.gradient-4 { background: linear-gradient(135deg, #f39c12, #e67e22); color: white; }

.stat-icon {
    font-size: 2rem;
    opacity: 0.8;
}

.stat-content h3 {
    font-size: 0.85rem;
    font-weight: 500;
    opacity: 0.9;
    margin-bottom: 5px;
}

.stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    line-height: 1.2;
}

.stat-trend {
    font-size: 0.75rem;
    opacity: 0.8;
    display: flex;
    align-items: center;
    gap: 3px;
    margin-top: 5px;
}

.stat-trend.positive { color: #2ecc71; }
.stat-trend.warning { color: #f39c12; }
.gradient-1 .stat-trend, .gradient-2 .stat-trend, 
.gradient-3 .stat-trend, .gradient-4 .stat-trend { color: rgba(255,255,255,0.9); }

/* Charts Row */
.charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 20px;
}

.chart-card {
    background: white;
    border-radius: 16px;
    padding: 18px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    height: 320px;
}

.chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.chart-header h3 {
    font-size: 0.95rem;
    font-weight: 600;
}

.chart-actions {
    display: flex;
    gap: 5px;
}

.chart-period {
    background: transparent;
    border: 1px solid #ddd;
    padding: 4px 10px;
    border-radius: 15px;
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
}

.chart-period.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
}

/* Info Row */
.info-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
    margin-bottom: 20px;
}

.activity-card, .recommendations-card {
    background: white;
    border-radius: 16px;
    padding: 18px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.card-header h3 {
    font-size: 0.95rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 8px;
}

.view-all {
    color: var(--primary);
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
}

/* Weather Alert */
.weather-alert-card {
    background: white;
    border-radius: 16px;
    padding: 18px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.weather-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.weather-title {
    display: flex;
    align-items: center;
    gap: 8px;
}

.weather-title h3 {
    font-size: 0.95rem;
    font-weight: 600;
}

/* ========== ANALYZE SECTION ========== */
.analyze-header {
    text-align: center;
    margin-bottom: 25px;
}

.analyze-header h2 {
    color: white;
    font-size: 1.8rem;
    margin-bottom: 8px;
}

.analyze-header p {
    color: rgba(255, 255, 255, 0.9);
}

.upload-advanced {
    background: white;
    border-radius: 20px;
    padding: 25px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
}

.upload-methods {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
}

.method-btn {
    flex: 1;
    padding: 12px;
    background: #f5f5f5;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 500;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: all 0.2s;
}

.method-btn.active {
    background: var(--primary);
    color: white;
}

.upload-area-enhanced {
    border: 2px dashed #ddd;
    border-radius: 16px;
    padding: 35px;
    text-align: center;
    transition: all 0.3s;
    margin-bottom: 20px;
}

.upload-area-enhanced:hover {
    border-color: var(--primary);
    background: rgba(46, 204, 113, 0.03);
}

.upload-icon {
    font-size: 3rem;
    color: var(--primary);
    margin-bottom: 15px;
}

.upload-zone h3 {
    margin-bottom: 8px;
}

.upload-zone p {
    color: #777;
    font-size: 0.9rem;
    margin-bottom: 20px;
}

.btn-primary {
    background: var(--primary);
    color: white;
    border: none;
    padding: 12px 24px;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: all 0.3s;
}

.btn-primary:hover {
    background: var(--primary-dark);
    transform: translateY(-2px);
}

.btn-analyze-large {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    border: none;
    padding: 16px 30px;
    border-radius: 12px;
    font-size: 1.1rem;
    font-weight: 600;
    cursor: pointer;
    width: 100%;
    margin-top: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: all 0.3s;
}

.btn-analyze-large:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(102, 126, 234, 0.4);
}

.analysis-options {
    margin: 20px 0;
}

.analysis-options h4 {
    margin-bottom: 12px;
    font-size: 0.95rem;
}

.options-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
}

.option-checkbox {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-size: 0.9rem;
}

.location-selection {
    margin: 20px 0;
}

.location-selection label {
    display: block;
    margin-bottom: 8px;
    font-weight: 500;
    font-size: 0.9rem;
}

.location-input {
    display: flex;
    gap: 10px;
}

.location-input input {
    flex: 1;
    padding: 12px 15px;
    border: 1px solid #ddd;
    border-radius: 10px;
    font-size: 0.9rem;
}

.btn-secondary {
    background: var(--secondary);
    color: white;
    border: none;
    padding: 12px 20px;
    border-radius: 10px;
    font-weight: 500;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 8px;
    white-space: nowrap;
}

/* ========== COMMUNITY SECTION ========== */
.community-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 25px;
}

.community-header h2 {
    color: white;
    font-size: 1.8rem;
}

.community-grid {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 25px;
}

.community-sidebar {
    background: white;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    height: fit-content;
}

.community-stats, .top-contributors, .popular-tags {
    margin-bottom: 25px;
}

.community-stats h4, .top-contributors h4, .popular-tags h4 {
    font-size: 0.9rem;
    margin-bottom: 15px;
    color: #555;
}

.stat-item {
    display: flex;
    justify-content: space-between;
    padding: 8px 0;
    border-bottom: 1px solid #eee;
}

.community-feed {
    background: white;
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.feed-filters {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
}

.filter-btn {
    background: transparent;
    border: none;
    padding: 8px 16px;
    border-radius: 20px;
    cursor: pointer;
    font-size: 0.85rem;
    transition: all 0.2s;
}

.filter-btn.active {
    background: var(--primary);
    color: white;
}

.tags-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.tag {
    background: #f0f0f0;
    padding: 5px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    text-decoration: none;
    color: #555;
    transition: all 0.2s;
}

.tag:hover {
    background: var(--primary);
    color: white;
}

/* ========== MAP SECTION ========== */
.map-header {
    margin-bottom: 25px;
}

.map-header h2 {
    color: white;
    font-size: 1.8rem;
    margin-bottom: 5px;
}

.map-header p {
    color: rgba(255, 255, 255, 0.9);
}

.map-container {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.15);
}

#diseaseMap {
    width: 100%;
    height: 450px;
    background: #e0e0e0;
}

.map-controls {
    position: absolute;
    bottom: 20px;
    right: 20px;
    display: flex;
    gap: 10px;
}

.map-legend {
    background: white;
    padding: 15px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    font-size: 0.85rem;
}

.legend-color {
    width: 12px;
    height: 12px;
    border-radius: 50%;
}

/* ========== LEARN SECTION ========== */
.learn-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 25px;
    margin: 30px 0;
}

.learn-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    transition: all 0.3s;
}

.learn-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
}

.card-image {
    position: relative;
}

.card-image img {
    width: 100%;
    height: 180px;
    object-fit: cover;
}

.card-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    background: var(--primary);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 600;
}

.card-content {
    padding: 20px;
}

.card-content h3 {
    font-size: 1.1rem;
    margin-bottom: 10px;
}

.card-content p {
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 15px;
}

.read-more {
    color: var(--primary);
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
    gap: 5px;
}

.video-tutorials {
    margin-top: 40px;
}

.video-tutorials h3 {
    color: white;
    margin-bottom: 20px;
}

.video-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
}

.video-card {
    background: white;
    border-radius: 16px;
    padding: 15px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.video-thumbnail {
    position: relative;
    margin-bottom: 12px;
}

.video-thumbnail img {
    width: 100%;
    height: 140px;
    object-fit: cover;
    border-radius: 10px;
}

.video-thumbnail i {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 3rem;
    color: white;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
}

.video-card h4 {
    font-size: 0.95rem;
    margin-bottom: 5px;
}

.video-card span {
    font-size: 0.8rem;
    color: #888;
}

/* ========== HISTORY SECTION ========== */
.history-header {
    margin-bottom: 25px;
}

.history-header h2 {
    color: white;
    font-size: 1.8rem;
    margin-bottom: 15px;
}

.history-filters {
    display: flex;
    gap: 15px;
    flex-wrap: wrap;
}

.history-filters input {
    flex: 1;
    min-width: 200px;
    padding: 12px 15px;
    border: none;
    border-radius: 10px;
    font-size: 0.9rem;
}

.history-filters select {
    padding: 12px 15px;
    border: none;
    border-radius: 10px;
    font-size: 0.9rem;
    background: white;
}

.history-grid {
    display: grid;
    gap: 15px;
    margin-bottom: 25px;
}

.history-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 20px;
}

.page-btn {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.page-btn:hover:not(:disabled) {
    background: var(--primary);
    color: white;
}

.page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.page-info {
    color: white;
    font-weight: 500;
}

/* ========== FAB ========== */
.fab-container {
    position: fixed;
    bottom: 30px;
    right: 30px;
    z-index: 999;
}

.fab-main {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border: none;
    color: white;
    font-size: 1.5rem;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
    transition: all 0.3s;
}

.fab-main:hover {
    transform: scale(1.1);
}

.fab-options {
    position: absolute;
    bottom: 70px;
    right: 0;
    display: none;
    flex-direction: column;
    gap: 10px;
}

.fab-container.active .fab-options {
    display: flex;
}

.fab-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    background: white;
    border: none;
    border-radius: 30px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s;
}

.fab-option:hover {
    transform: translateX(-5px);
    background: var(--primary);
    color: white;
}

/* ========== AI ASSISTANT ========== */
.ai-assistant {
    position: fixed;
    bottom: 100px;
    right: 30px;
    z-index: 1000;
}

.assistant-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea, #764ba2);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 20px rgba(102, 126, 234, 0.4);
    transition: all 0.3s;
    animation: float 3s ease-in-out infinite;
}

@keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
}

.assistant-avatar:hover {
    transform: scale(1.1);
}

.assistant-avatar i {
    font-size: 28px;
    color: white;
}

.assistant-chat {
    position: absolute;
    bottom: 80px;
    right: 0;
    width: 350px;
    height: 450px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    display: flex;
    flex-direction: column;
    overflow: hidden;
}

.chat-header {
    padding: 15px 20px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.close-chat {
    background: transparent;
    border: none;
    color: white;
    cursor: pointer;
    font-size: 1.2rem;
}

.chat-messages {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
}

.message {
    margin-bottom: 15px;
    padding: 10px 15px;
    border-radius: 15px;
    max-width: 80%;
}

.message.bot {
    background: #f0f0f0;
    align-self: flex-start;
}

.message.user {
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    align-self: flex-end;
    margin-left: auto;
}

.chat-input {
    padding: 15px;
    border-top: 1px solid #eee;
    display: flex;
    gap: 10px;
}

.chat-input input {
    flex: 1;
    padding: 10px 15px;
    border: 1px solid #ddd;
    border-radius: 25px;
    outline: none;
}

.chat-input button {
    width: 45px;
    height: 45px;
    border-radius: 50%;
    background: linear-gradient(135deg, #667eea, #764ba2);
    border: none;
    color: white;
    cursor: pointer;
}

/* ========== NOTIFICATION PANEL ========== */
.notification-panel {
    position: fixed;
    top: 80px;
    right: 20px;
    width: 350px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    z-index: 1001;
    overflow: hidden;
}

.panel-header {
    padding: 15px 20px;
    border-bottom: 1px solid #eee;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.panel-header h3 {
    font-size: 1rem;
}

.mark-all-read {
    background: none;
    border: none;
    color: var(--primary);
    font-size: 0.8rem;
    cursor: pointer;
}

.notification-item {
    display: flex;
    gap: 12px;
    padding: 15px 20px;
    border-bottom: 1px solid #f0f0f0;
    cursor: pointer;
    transition: background 0.2s;
}

.notification-item:hover {
    background: #f8f9fa;
}

.notification-item.unread {
    background: rgba(46, 204, 113, 0.05);
}

.notification-item i {
    color: var(--primary);
    font-size: 1.2rem;
}

.notification-content p {
    font-size: 0.9rem;
    margin-bottom: 3px;
}

.notification-content span {
    font-size: 0.75rem;
    color: #888;
}

/* ========== OUTBREAK STATS ========== */
.outbreak-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 25px;
}

.stat-box {
    background: white;
    border-radius: 16px;
    padding: 20px;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
}

.stat-box h4 {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 10px;
}

.stat-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary);
}

.stat-text {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--danger);
}

/* ========== DARK MODE ========== */
[data-theme="dark"] .navbar {
    background: rgba(26, 35, 44, 0.95) !important;
    border-bottom: 1px solid #2a3743 !important;
}

[data-theme="dark"] .nav-link {
    color: #9baab8 !important;
}

[data-theme="dark"] .nav-link:hover {
    color: var(--primary) !important;
    background: rgba(46, 204, 113, 0.1) !important;
}

[data-theme="dark"] .nav-link.active {
    background: var(--primary) !important;
    color: white !important;
}

[data-theme="dark"] .user-profile {
    background: rgba(255, 255, 255, 0.05) !important;
}

[data-theme="dark"] .user-profile span {
    color: #e8edf2 !important;
}

[data-theme="dark"] .user-dropdown {
    background: #1a232c !important;
    border: 1px solid #2a3743 !important;
}

[data-theme="dark"] .user-dropdown a {
    color: #e8edf2 !important;
}

[data-theme="dark"] .user-dropdown a:hover {
    background: #212c38 !important;
}

[data-theme="dark"] .dropdown-divider {
    background: #2a3743 !important;
}

[data-theme="dark"] .stat-card,
[data-theme="dark"] .chart-card,
[data-theme="dark"] .activity-card,
[data-theme="dark"] .recommendations-card,
[data-theme="dark"] .weather-alert-card,
[data-theme="dark"] .upload-advanced,
[data-theme="dark"] .community-sidebar,
[data-theme="dark"] .community-feed,
[data-theme="dark"] .learn-card,
[data-theme="dark"] .video-card,
[data-theme="dark"] .map-legend,
[data-theme="dark"] .stat-box,
[data-theme="dark"] .notification-panel {
    background: #1a232c !important;
    border: 1px solid #2a3743 !important;
}

[data-theme="dark"] .assistant-chat {
    background: #1a232c !important;
    border: 1px solid #2a3743 !important;
}

[data-theme="dark"] .message.bot {
    background: #212c38 !important;
    color: #e8edf2 !important;
}

[data-theme="dark"] .chat-input {
    border-top-color: #2a3743 !important;
}

[data-theme="dark"] .chat-input input {
    background: #212c38 !important;
    border-color: #2a3743 !important;
    color: #e8edf2 !important;
}

/* ========== RESPONSIVE ========== */
@media (max-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .charts-row { grid-template-columns: 1fr; }
    .info-row { grid-template-columns: 1fr; }
    .community-grid { grid-template-columns: 1fr; }
    .learn-grid { grid-template-columns: repeat(2, 1fr); }
    .video-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 768px) {
    .nav-menu { display: none; }
    .stats-grid { grid-template-columns: 1fr; }
    .learn-grid { grid-template-columns: 1fr; }
    .video-grid { grid-template-columns: 1fr; }
    .options-grid { grid-template-columns: 1fr; }
    .location-input { flex-direction: column; }
    .assistant-chat { width: 300px; height: 400px; }
    .user-profile span { display: none; }
    .user-profile { padding: 6px; }
}
/* ========== USER PROFILE DROPDOWN - POPUP STYLE ========== */
.user-profile-wrapper {
    position: relative;
}

.user-profile {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    background: rgba(0, 0, 0, 0.03);
    border-radius: 30px;
    cursor: pointer;
    transition: all 0.3s;
}

.user-profile:hover {
    background: rgba(46, 204, 113, 0.1);
}

.user-profile img {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--primary);
}

.user-profile span {
    font-weight: 500;
    color: #333;
    font-size: 0.9rem;
}

.user-profile i {
    font-size: 0.75rem;
    color: #888;
    transition: transform 0.3s;
}

.user-profile.active i {
    transform: rotate(180deg);
}

/* Popup Style Dropdown - Same as Notification Panel */
.user-dropdown {
    position: fixed;
    top: 80px;
    right: 20px;
    width: 300px;
    background: white;
    border-radius: 16px;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    z-index: 1001;
    overflow: hidden;
    animation: slideDown 0.3s ease;
    border: 1px solid rgba(255, 255, 255, 0.2);
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Dropdown Header Arrow */
.user-dropdown::before {
    content: '';
    position: absolute;
    top: -8px;
    right: 30px;
    width: 16px;
    height: 16px;
    background: white;
    transform: rotate(45deg);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    border-left: 1px solid rgba(0, 0, 0, 0.05);
}

.user-dropdown .dropdown-header {
    padding: 20px;
    background: linear-gradient(135deg, #667eea, #764ba2);
    color: white;
    display: flex;
    align-items: center;
    gap: 15px;
}

.user-dropdown .dropdown-header img {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 3px solid white;
}

.user-dropdown .dropdown-header i {
    font-size: 28px;
    color: white;
}

.user-dropdown .dropdown-header .user-info h4 {
    font-size: 1rem;
    margin-bottom: 4px;
}

.user-dropdown .dropdown-header .user-info p {
    font-size: 0.8rem;
    opacity: 0.9;
}

.user-dropdown .dropdown-body {
    padding: 8px 0;
}

.user-dropdown a {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 20px;
    text-decoration: none;
    color: #333;
    transition: all 0.2s;
    font-size: 0.95rem;
}

.user-dropdown a i {
    width: 22px;
    color: var(--primary);
    font-size: 1.1rem;
}

.user-dropdown a:hover {
    background: #f5f5f5;
    padding-left: 25px;
}

.user-dropdown .dropdown-divider {
    height: 1px;
    background: #eee;
    margin: 8px 0;
}

.user-dropdown .logout-btn {
    color: var(--danger) !important;
}

.user-dropdown .logout-btn i {
    color: var(--danger) !important;
}

/* Dark Mode Support for Dropdown */
[data-theme="dark"] .user-dropdown {
    background: #1a232c;
    border: 1px solid #2a3743;
}

[data-theme="dark"] .user-dropdown::before {
    background: #1a232c;
    border-top: 1px solid #2a3743;
    border-left: 1px solid #2a3743;
}

[data-theme="dark"] .user-dropdown a {
    color: #e8edf2;
}

[data-theme="dark"] .user-dropdown a:hover {
    background: #212c38;
}

[data-theme="dark"] .user-dropdown .dropdown-divider {
    background: #2a3743;
}

[data-theme="dark"] .user-profile span {
    color: #e8edf2;
}

[data-theme="dark"] .user-profile {
    background: rgba(255, 255, 255, 0.05);
}

